# Global .gitignore for Kohsha Academy Project

# Dependencies
**/node_modules/
**/package-lock.json
**/yarn.lock
**/pnpm-lock.yaml

# Environment files
**/.env
**/.env.local
**/.env.*.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Build outputs
**/dist/
**/build/
**/.next/
**/out/
**/.parcel-cache/
**/coverage/

# Logs
**/*.log
**/logs/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
*.sublimetext-project
*.sublimetext-workspace

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Misc
.cache/
.eslintcache
.turbo/
*.tsbuildinfo
.venv/
venv/
.pytest_cache/
.mypy_cache/
**/__pycache__/

# Temporary files
**/temp/
**/tmp/
**/.tmp/

# Uploads (server-specific, but good to have globally)
**/uploads/
**/public/uploads/

# IDE specific
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Testing
.nyc_output/
.coverage
htmlcov/

# Compiled files
*.class
*.jar
*.war
*.ear

# Keep these patterns if using specific tools
# For Python development
pip-log.txt
pip-delete-this-directory.txt

# For Node.js
.npm
.eslintignore
